{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signature-visual.pages.dev/schemas/visual-qa-manifest-v3.schema.json",
  "title": "Signature Visual QA Manifest V3",
  "type": "object",
  "required": ["schemaVersion", "url", "states"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 3 },
    "name": { "type": "string", "minLength": 1 },
    "tier": { "enum": ["capture", "interaction", "production"] },
    "serveRoot": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "minLength": 1 },
    "outputDir": { "type": "string", "minLength": 1 },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "deviceScaleFactor": { "type": "number", "exclusiveMinimum": 0, "maximum": 4 }
      }
    },
    "captureSelector": { "type": "string", "minLength": 1 },
    "readySelector": { "type": "string", "minLength": 1 },
    "hook": { "type": "string", "minLength": 1 },
    "seed": { "type": ["string", "number"] },
    "epoch": { "type": ["string", "number"] },
    "locale": { "type": "string", "minLength": 1 },
    "timezoneId": { "type": "string", "minLength": 1 },
    "reducedMotion": { "enum": ["reduce", "no-preference"] },
    "colorScheme": { "enum": ["light", "dark", "no-preference"] },
    "fullPage": { "type": "boolean" },
    "failOnConsoleError": { "type": "boolean" },
    "failOnNetworkError": { "type": "boolean" },
    "timeoutMs": { "type": "integer", "minimum": 1 },
    "derivedImages": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "thumbnailWidth": { "type": "integer", "minimum": 80, "maximum": 640 },
        "blurRadius": { "type": "integer", "minimum": 12, "maximum": 16 },
        "silhouette": { "type": "boolean" }
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/captureState" }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resize": { "$ref": "#/$defs/capability" },
        "zeroSize": { "$ref": "#/$defs/capability" },
        "pointer": { "$ref": "#/$defs/capability" },
        "windowFocus": { "$ref": "#/$defs/capability" },
        "keyboard": { "$ref": "#/$defs/capability" },
        "reducedMotion": { "$ref": "#/$defs/capability" },
        "lifecycle": { "$ref": "#/$defs/capability" },
        "gpu": { "$ref": "#/$defs/capability" },
        "primaryAction": { "$ref": "#/$defs/capability" }
      }
    },
    "runtimeScenarios": {
      "type": "array",
      "items": { "$ref": "#/$defs/runtimeScenario" }
    }
  },
  "$defs": {
    "pointerEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "atMs": { "type": "number", "minimum": 0 },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "active": { "type": "boolean" },
        "leave": { "type": "boolean" },
        "unit": { "enum": ["ratio", "px"] },
        "steps": { "type": "integer", "minimum": 1 },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "captureState": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "timeMs": { "type": "number", "minimum": 0 },
        "settleMs": { "type": "number", "minimum": 0 },
        "pointer": {
          "oneOf": [
            { "$ref": "#/$defs/pointerEvent" },
            { "type": "array", "items": { "$ref": "#/$defs/pointerEvent" } }
          ]
        }
      },
      "anyOf": [
        { "required": ["progress"], "properties": { "progress": true } },
        { "required": ["timeMs"], "properties": { "timeMs": true } },
        { "required": ["pointer"], "properties": { "pointer": true } }
      ]
    },
    "capability": {
      "oneOf": [
        { "const": true },
        {
          "type": "object",
          "required": ["supported"],
          "additionalProperties": false,
          "properties": {
            "supported": { "const": true },
            "note": { "type": "string" },
            "target": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["supported", "reason"],
          "additionalProperties": false,
          "properties": {
            "supported": { "const": false },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "runtimeScenario": {
      "type": "object",
      "required": ["name", "requires", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "requires": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["resize", "zeroSize", "pointer", "windowFocus", "keyboard", "reducedMotion", "lifecycle", "gpu", "primaryAction"]
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["action"],
            "properties": { "action": { "type": "string", "minLength": 1 } },
            "additionalProperties": true
          }
        }
      }
    }
  }
}
