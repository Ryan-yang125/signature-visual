{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signature-visual.pages.dev/schemas/visual-qa-results-v3.schema.json",
  "title": "Signature Visual QA Results V3",
  "type": "object",
  "required": [
    "schemaVersion",
    "sourceSchemaVersion",
    "tier",
    "name",
    "sourceManifest",
    "url",
    "seed",
    "epoch",
    "viewport",
    "reducedMotion",
    "colorScheme",
    "captureSelector",
    "derivedImages",
    "states",
    "runtime",
    "contactSheet",
    "hashPurpose"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 3 },
    "sourceSchemaVersion": { "enum": [1, 3] },
    "tier": { "enum": ["capture", "interaction", "production"] },
    "name": { "type": "string", "minLength": 1 },
    "sourceManifest": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/\\\\]+\\.json$"
    },
    "url": { "type": "string", "minLength": 1 },
    "seed": { "type": "string", "minLength": 1 },
    "epoch": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "number" }
      ]
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height", "deviceScaleFactor"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "deviceScaleFactor": { "type": "number", "exclusiveMinimum": 0, "maximum": 4 }
      }
    },
    "reducedMotion": { "enum": ["reduce", "no-preference"] },
    "colorScheme": {
      "oneOf": [
        { "enum": ["light", "dark", "no-preference"] },
        { "type": "null" }
      ]
    },
    "captureSelector": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "derivedImages": {
      "type": "object",
      "required": ["thumbnailWidth", "blurRadius", "silhouette"],
      "additionalProperties": false,
      "properties": {
        "thumbnailWidth": { "type": "integer", "minimum": 80, "maximum": 640 },
        "blurRadius": { "type": "integer", "minimum": 12, "maximum": 16 },
        "silhouette": { "type": "boolean" }
      }
    },
    "hashPurpose": { "const": "determinism-only" },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stateResult" }
    },
    "runtime": {
      "type": "object",
      "required": ["capabilities", "scenarios"],
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "resize": { "$ref": "#/$defs/capability" },
            "zeroSize": { "$ref": "#/$defs/capability" },
            "pointer": { "$ref": "#/$defs/capability" },
            "windowFocus": { "$ref": "#/$defs/capability" },
            "keyboard": { "$ref": "#/$defs/capability" },
            "reducedMotion": { "$ref": "#/$defs/capability" },
            "lifecycle": { "$ref": "#/$defs/capability" },
            "gpu": { "$ref": "#/$defs/capability" },
            "primaryAction": { "$ref": "#/$defs/capability" }
          }
        },
        "scenarios": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeScenarioResult" }
        }
      }
    },
    "contactSheet": {
      "type": "object",
      "required": ["html", "png"],
      "additionalProperties": false,
      "properties": {
        "html": { "type": "string", "minLength": 1 },
        "png": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["tier"],
        "properties": { "tier": { "const": "production" } }
      },
      "then": {
        "properties": {
          "runtime": {
            "type": "object",
            "properties": {
              "capabilities": {
                "type": "object",
                "properties": {
                  "resize": true,
                  "zeroSize": true,
                  "pointer": true,
                  "windowFocus": true,
                  "keyboard": true,
                  "reducedMotion": true,
                  "lifecycle": true,
                  "gpu": true,
                  "primaryAction": true
                },
                "required": [
                  "resize",
                  "zeroSize",
                  "pointer",
                  "windowFocus",
                  "keyboard",
                  "reducedMotion",
                  "lifecycle",
                  "gpu",
                  "primaryAction"
                ]
              },
              "scenarios": { "type": "array", "minItems": 1 }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "diagnostics": {
      "type": "object",
      "required": ["consoleErrors", "pageErrors", "networkErrors"],
      "additionalProperties": false,
      "properties": {
        "consoleErrors": { "type": "array", "items": { "type": "string" } },
        "pageErrors": { "type": "array", "items": { "type": "string" } },
        "networkErrors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "derived": {
      "type": "object",
      "required": ["thumbnail", "blur", "silhouette"],
      "additionalProperties": false,
      "properties": {
        "thumbnail": { "type": "string", "minLength": 1 },
        "blur": { "type": "string", "minLength": 1 },
        "silhouette": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        }
      }
    },
    "pointerEvent": {
      "type": "object",
      "required": ["atMs", "x", "y", "active", "unit", "target"],
      "additionalProperties": false,
      "properties": {
        "atMs": { "type": "number", "minimum": 0 },
        "x": { "type": ["number", "null"] },
        "y": { "type": ["number", "null"] },
        "active": { "type": "boolean" },
        "unit": { "enum": ["ratio", "px"] },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "description": {
      "type": ["object", "null"],
      "minProperties": 1
    },
    "stateResult": {
      "type": "object",
      "required": [
        "name",
        "summary",
        "file",
        "sha256",
        "pointer",
        "derived",
        "description",
        "diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "timeMs": { "type": "number", "minimum": 0 },
        "pointer": {
          "type": "array",
          "items": { "$ref": "#/$defs/pointerEvent" }
        },
        "derived": { "$ref": "#/$defs/derived" },
        "description": { "$ref": "#/$defs/description" },
        "diagnostics": { "$ref": "#/$defs/diagnostics" }
      },
      "anyOf": [
        { "required": ["progress"], "properties": { "progress": true } },
        { "required": ["timeMs"], "properties": { "timeMs": true } },
        { "properties": { "pointer": { "type": "array", "minItems": 1 } } }
      ]
    },
    "capability": {
      "oneOf": [
        {
          "type": "object",
          "required": ["supported"],
          "additionalProperties": false,
          "properties": {
            "supported": { "const": true },
            "note": { "type": "string" },
            "target": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["supported", "reason"],
          "additionalProperties": false,
          "properties": {
            "supported": { "const": false },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "runtimeStepResult": {
      "type": "object",
      "required": ["action", "passed", "detail"],
      "additionalProperties": false,
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "passed": { "const": true },
        "detail": { "type": "object", "minProperties": 1 }
      }
    },
    "runtimeScenarioResult": {
      "type": "object",
      "required": [
        "name",
        "requires",
        "passed",
        "assertionCount",
        "steps",
        "description",
        "diagnostics"
      ],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "requires": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "resize",
              "zeroSize",
              "pointer",
              "windowFocus",
              "keyboard",
              "reducedMotion",
              "lifecycle",
              "gpu",
              "primaryAction"
            ]
          }
        },
        "passed": { "const": true },
        "assertionCount": { "type": "integer", "minimum": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/runtimeStepResult" }
        },
        "description": { "$ref": "#/$defs/description" },
        "diagnostics": { "$ref": "#/$defs/diagnostics" }
      }
    }
  }
}
