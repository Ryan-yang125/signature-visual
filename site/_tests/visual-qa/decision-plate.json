{
  "schemaVersion": 3,
  "tier": "production",
  "name": "Decision Plate 027 — motion score",
  "serveRoot": "../../",
  "url": "/examples/spatial-lineage/",
  "outputDir": "../../../.visual-qa/decision-plate",
  "viewport": { "width": 1400, "height": 900, "deviceScaleFactor": 1 },
  "captureSelector": ".decision-room",
  "readySelector": "#diagram",
  "seed": "decision-plate-v3",
  "failOnNetworkError": true,
  "capabilities": {
      "resize": true,
      "zeroSize": true,
      "pointer": true,
      "windowFocus": true,
      "keyboard": true,
      "reducedMotion": true,
      "lifecycle": true,
      "gpu": {
        "supported": false,
        "reason": "This case uses semantic SVG and has no GPU context."
      },
      "primaryAction": {
        "supported": false,
        "reason": "Node inspection is the artifact interaction; the plate contains no primary CTA."
      }
    },
    "runtimeScenarios": [
      {
        "name": "resize and zero-size recovery",
        "requires": [
          "resize",
          "zeroSize"
        ],
        "steps": [
          {
            "action": "setReducedMotion",
            "value": "no-preference"
          },
          {
            "action": "setOwnerSize",
            "selector": ".decision-room",
            "width": 0,
            "height": 0
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": true
          },
          {
            "action": "assertHook",
            "path": "pauseReasons",
            "includes": "zero-size"
          },
          {
            "action": "assertHook",
            "path": "resources.raf",
            "equals": 0
          },
          {
            "action": "setOwnerSize",
            "selector": ".decision-room",
            "width": 1180,
            "height": 760
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": false
          },
          {
            "action": "setViewport",
            "width": 1160,
            "height": 760
          },
          {
            "action": "assertHook",
            "path": "ready",
            "equals": true
          },
          {
            "action": "assertNoErrors"
          }
        ]
      },
      {
        "name": "pointer cancellation and focus recovery",
        "requires": [
          "pointer",
          "windowFocus"
        ],
        "steps": [
          {
            "action": "setReducedMotion",
            "value": "no-preference"
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "pointerenter",
            "x": 0.62,
            "y": 0.44
          },
          {
            "action": "assertHook",
            "path": "pointer.active",
            "equals": true
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "pointercancel"
          },
          {
            "action": "assertHook",
            "path": "pointer.active",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "pointer.lastEvent",
            "equals": "pointercancel"
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "pointerenter",
            "x": 0.48,
            "y": 0.56
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "pointerleave"
          },
          {
            "action": "assertHook",
            "path": "pointer.active",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "pointer.lastEvent",
            "equals": "pointerleave"
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "pointerenter",
            "x": 0.54,
            "y": 0.48
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "lostpointercapture"
          },
          {
            "action": "assertHook",
            "path": "pointer.active",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "pointer.lastEvent",
            "equals": "lostpointercapture"
          },
          {
            "action": "pointerEvent",
            "selector": ".node[data-node=\"review\"]",
            "event": "pointerenter",
            "x": 0.58,
            "y": 0.5
          },
          {
            "action": "windowBlur"
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": true
          },
          {
            "action": "assertHook",
            "path": "pauseReasons",
            "includes": "window-blur"
          },
          {
            "action": "assertHook",
            "path": "pointer.active",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "pointer.lastEvent",
            "equals": "window-blur"
          },
          {
            "action": "windowFocus"
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": false
          },
          {
            "action": "assertNoErrors"
          }
        ]
      },
      {
        "name": "runtime reduced-motion change",
        "requires": [
          "reducedMotion"
        ],
        "steps": [
          {
            "action": "setReducedMotion",
            "value": "no-preference"
          },
          {
            "action": "assertHook",
            "path": "reducedMotion",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": false
          },
          {
            "action": "setReducedMotion",
            "value": "reduce"
          },
          {
            "action": "assertHook",
            "path": "reducedMotion",
            "equals": true
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": true
          },
          {
            "action": "assertHook",
            "path": "pauseReasons",
            "includes": "reduced-motion"
          },
          {
            "action": "setReducedMotion",
            "value": "no-preference"
          },
          {
            "action": "assertHook",
            "path": "reducedMotion",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "paused",
            "equals": false
          },
          {
            "action": "assertNoErrors"
          }
        ]
      },
      {
        "name": "idempotent dispose and clean remount",
        "requires": [
          "lifecycle"
        ],
        "steps": [
          {
            "action": "setReducedMotion",
            "value": "no-preference"
          },
          {
            "action": "assertHook",
            "path": "resources.listeners",
            "truthy": true
          },
          {
            "action": "assertHook",
            "path": "resources.observers",
            "truthy": true
          },
          {
            "action": "dispose"
          },
          {
            "action": "assertHook",
            "path": "disposed",
            "equals": true
          },
          {
            "action": "assertHook",
            "path": "ready",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "resources.listeners",
            "equals": 0
          },
          {
            "action": "assertHook",
            "path": "resources.observers",
            "equals": 0
          },
          {
            "action": "assertHook",
            "path": "resources.raf",
            "equals": 0
          },
          {
            "action": "dispose"
          },
          {
            "action": "assertHook",
            "path": "disposeCount",
            "equals": 1
          },
          {
            "action": "remount"
          },
          {
            "action": "assertHook",
            "path": "disposed",
            "equals": false
          },
          {
            "action": "assertHook",
            "path": "ready",
            "equals": true
          },
          {
            "action": "assertHook",
            "path": "mountCount",
            "equals": 2
          },
          {
            "action": "assertHook",
            "path": "resources.listeners",
            "truthy": true
          },
          {
            "action": "assertHook",
            "path": "resources.observers",
            "truthy": true
          },
          {
            "action": "assertNoErrors"
          }
        ]
      },
      {
        "name": "keyboard-equivalent node inspection",
        "requires": [
          "keyboard"
        ],
        "steps": [
          {
            "action": "setReducedMotion",
            "value": "no-preference"
          },
          {
            "action": "keyboard",
            "selector": ".node[data-node=\"review\"]",
            "key": "Enter"
          },
          {
            "action": "assertFocus",
            "selector": ".node[data-node=\"review\"]"
          },
          {
            "action": "assertHook",
            "path": "focusedNode",
            "equals": "review"
          },
          {
            "action": "assertHook",
            "path": "action.last",
            "equals": "review"
          },
          {
            "action": "assertHook",
            "path": "action.source",
            "equals": "keyboard"
          },
          {
            "action": "assertNoErrors"
          }
        ]
      }
    ]
  ,
  "states": [
    { "name": "intake", "progress": 0.06 },
    { "name": "frame", "progress": 0.25 },
    { "name": "branch", "progress": 0.43 },
    { "name": "review", "progress": 0.62, "pointer": { "atMs": 0, "x": 0.58, "y": 0.6, "target": "#diagram" } },
    { "name": "commit", "progress": 0.8 },
    { "name": "archive", "progress": 0.94 }
  ]
}
